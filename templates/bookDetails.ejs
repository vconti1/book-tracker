<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Book Details</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://kit.fontawesome.com/73117c85c2.js" crossorigin="anonymous"></script>
</head>
<body>
  <div class="navbar">
    <h1><i class="fa-solid fa-book-open-reader"></i>Book Tracker</h1>
    <nav>
      <a href="/"><i class="fa-solid fa-house"></i>Home</a>
      <a href="/search"><i class="fa-solid fa-magnifying-glass"></i>Search Books</a>
      <a href="/library" class="active"><i class="fa-solid fa-book-open"></i>My Library</a>
      <a href="/stats"><i class="fa-solid fa-chart-column"></i>Stats</a>
    </nav>
  </div>

  <main class="details-page">
    <div id="book-details"></div>
  </main>

  <script>
    var id = window.location.pathname.split("/")[2];

    fetch(`/library/${id}/data`)
      .then(function(res) { return res.json(); })
      .then(function(book) {
        var container = document.getElementById("book-details");

        var cover = "";
        if (book.coverId) {
          cover = `<img src="https://covers.openlibrary.org/b/id/${book.coverId}-L.jpg" alt="cover">`;
        }

        var year = "";
        if (book.firstPublishYear) {
          year = `<p><strong>First published:</strong> ${book.firstPublishYear}</p>`;
        }

        var rating = "";
        if (book.rating) {
          rating = `<p><strong>Rating:</strong> ${book.rating}/5</p>`;
        }

        var notes = "";
        if (book.notes) {
          notes = `<p><strong>Notes:</strong> ${book.notes}</p>`;
        }

        var dateFinished = "";
        if (book.dateFinished) {
          dateFinished = `<p><strong>Date finished:</strong> ${new Date(book.dateFinished).toDateString()}</p>`;
        }

        container.innerHTML = 
          `<section class="details-card">
            <div class="details-cover">
              ${cover || "<p><em>No cover available</em></p>"}
            </div>

            <div class="details-info">
              <h2>${book.title}</h2>

              <p><strong>Author:</strong> ${book.author}</p>
              ${year}
              <p><strong>Status:</strong> ${book.status}</p>
              ${rating}
              ${notes}
              <p><strong>Date added:</strong> ${new Date(book.dateAdded).toDateString()}</p>
              ${dateFinished}

              <div class="details-actions">
                <a class="edit-btn" href="/library/${book._id}/edit">
                  <i class="fa-solid fa-pen"></i>Edit
                </a>

                <form action="/library/${book._id}/delete" method="POST" class="delete-form">
                  <button type="submit" class="delete-btn">
                    <i class="fa-solid fa-trash"></i>Delete
                  </button>
                </form>

                <a class="back-btn" href="/library">
                  Back to Library
                </a>
              </div>
            </div>
          </section>`;
      });
  </script>
</body>
</html>
