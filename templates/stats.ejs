</head>
<body>
  <div class="navbar">
    <h1><i class="fa-solid fa-book-open-reader"></i>Book Tracker</h1>

    <nav>
      <a href="/"><i class="fa-solid fa-house"></i>Home</a>
      <a href="/search"><i class="fa-solid fa-magnifying-glass"></i>Search Books</a>
      <a href="/library"><i class="fa-solid fa-book-open"></i>My Library</a>
      <a href="/stats" class="active"><i class="fa-solid fa-chart-column"></i>Stats</a>
    </nav>
  </div>

  <main class="stats-page">
    <section class="stats-header">
      <h1>Reading Stats</h1>
      <p class="subtitle">Your library at a glance</p>
    </section>

    <section class="stats-grid">
      <div class="stat-card total">
        <div class="stat-icon"><i class="fa-solid fa-book"></i></div>
        <div class="label">Total Books</div>
        <div class="value"><%= stats.total %></div>
        <div class="sub">in your library</div>
      </div>

      <div class="stat-card toread">
        <div class="stat-icon"><i class="fa-solid fa-bookmark"></i></div>
        <div class="label">To Read</div>
        <div class="value"><%= stats.toRead %></div>
        <div class="sub">on the backlog</div>
      </div>

      <div class="stat-card reading">
        <div class="stat-icon"><i class="fa-solid fa-book-open"></i></div>
        <div class="label">Reading</div>
        <div class="value"><%= stats.reading %></div>
        <div class="sub">in progress</div>
      </div>

      <div class="stat-card finished">
        <div class="stat-icon"><i class="fa-solid fa-check"></i></div>
        <div class="label">Finished</div>
        <div class="value"><%= stats.finished %></div>
        <div class="sub">completed</div>
      </div>

      <% if (stats.avgRating) { %>
        <div class="stat-card rating">
          <div class="stat-icon"><i class="fa-solid fa-star"></i></div>
          <div class="label">Avg Rating</div>
          <div class="value"><%= stats.avgRating %></div>
          <div class="sub">across <%= stats.ratedCount %> rated books</div>
        </div>
      <% } %>
    </section>

    <a class="back-btn" href="/library">Back to Library</a>
  </main>
</body>
</html>