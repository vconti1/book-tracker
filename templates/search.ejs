<!--
  Search page template.

  This page should contain a form where users can search for books by:
  - Title
  - Author
  - Keyword

  The form should submit the user's search term to the search route.
-->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search</title>
</head>
<body>

  <h1>Search for a Book</h1>

  <form action="/search/results" method="GET">
    <label for="bookSearch">Search for a book:</label>

    <input
      type="text"
      id="bookSearch"
      name="q"
      placeholder="Enter title, author, or ISBN"
      required
    />

    <button type="submit">Search</button>
  </form>

</body>
</html>