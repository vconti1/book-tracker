<!--
  Home page template.

  This page should introduce the Book Tracker app and give users links to:
  - Search for books
  - View their saved library
  - View reading stats
-->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Book Tracker</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://kit.fontawesome.com/73117c85c2.js" crossorigin="anonymous"></script>
</head>
<body>
   <div class="navbar">
  <h1 ><i class="fa-solid fa-book-open-reader"></i>Book Tracker</h1>

  <nav>
    <a href="/" class="active"> <i class="fa-solid fa-house"></i>Home</a>
    <a href="/search"> <i class="fa-solid fa-magnifying-glass"></i>Search Books</a>
    <a href="/library"> <i class="fa-solid fa-book-open"></i>My Library</a>
    <a href="/stats" ><i class="fa-solid fa-chart-column"></i>Stats</a>
  </nav>

  </div>
  <main>
    <h2>Welcome</h2>

    <p>
      Book Tracker lets you search for books using the Open Library API,
      save books to your personal library, and track whether you want to read,
      are currently reading, or have finished each book.
    </p>

    <p>
      Use the navigation links above to search for books or view your saved library.
    </p>
  </main>
</body>
</html>