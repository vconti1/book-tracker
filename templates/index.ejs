<!--
  Home page template.

  This page should introduce the Book Tracker app and give users links to:
  - Search for books
  - View their saved library
  - View reading stats
-->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Book Tracker</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <h1>Book Tracker</h1>

  <nav>
    <a href="/">Home</a>
    <a href="/search">Search Books</a>
    <a href="/library">My Library</a>
    <a href="/stats">Stats</a>
  </nav>

  <main>
    <h2>Welcome</h2>

    <p>
      Book Tracker lets you search for books using the Open Library API,
      save books to your personal library, and track whether you want to read,
      are currently reading, or have finished each book.
    </p>

    <p>
      Use the navigation links above to search for books or view your saved library.
    </p>
  </main>
</body>
</html>