<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Book</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://kit.fontawesome.com/73117c85c2.js" crossorigin="anonymous"></script>
</head>
<body>
  <div class="navbar">
    <h1><i class="fa-solid fa-book-open-reader"></i>Book Tracker</h1>
    <nav>
      <a href="/"><i class="fa-solid fa-house"></i>Home</a>
      <a href="/search"><i class="fa-solid fa-magnifying-glass"></i>Search Books</a>
      <a href="/library"><i class="fa-solid fa-book-open"></i>My Library</a>
      <a href="/stats"><i class="fa-solid fa-chart-column"></i>Stats</a>
    </nav>
  </div>

<main class="edit-page">
  <section class="edit-header">
    <h2>Edit Book</h2>
    <p>Update your reading status, rating, and notes.</p>
  </section>

  <div id="edit-container"></div>
</main>

  <script>
    var id = window.location.pathname.split("/")[2];

    fetch(`/library/${id}/data`)
      .then(function(res) { return res.json(); })
      .then(function(book) {
        var container = document.getElementById("edit-container");

        container.innerHTML = 
          `<section class="edit-card">
          <h3>${book.title}</h3>

          <form action="/library/${book._id}/edit" method="POST" class="edit-form">

            <div class="form-group">
              <label>Status</label>
              <select name="status">
                <option value="To Read">To Read</option>
                <option value="Reading">Reading</option>
                <option value="Finished">Finished</option>
              </select>
            </div>

            <div class="form-group">
              <label>Rating (1-5)</label>
              <input type="number" name="rating" min="1" max="5" value="${book.rating || ""}">
            </div>

            <div class="form-group">
              <label>Notes</label>
              <textarea name="notes">${book.notes || ""}</textarea>
            </div>

            <div class="form-group">
              <label>Date Finished</label>
              <input type="date" name="dateFinished" value="${book.dateFinished ? new Date(book.dateFinished).toISOString().split("T")[0] : ""}">
            </div>

            <div class="edit-actions">
              <button type="submit" class="save-btn">
                <i class="fa-solid fa-floppy-disk"></i>Save
              </button>

              <a class="cancel-btn" href="/library/${book._id}">
                Cancel
              </a>
            </div>

          </form>
        </section>`;

        var select = container.querySelector("select[name='status']");
        for (var i = 0; i < select.options.length; i++) {
          if (select.options[i].value === book.status) {
            select.options[i].selected = true;
          }
        }
      });
  </script>
</body>
</html>
